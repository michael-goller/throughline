{
  "rewrites": [
    { "source": "/api/install-ps/:token", "destination": "/api/install-ps/[token]" },
    { "source": "/api/install/:token", "destination": "/api/install/[token]" },
    { "source": "/api/download/:token", "destination": "/api/download/[token]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
